{
    "productName": "warmot",
    "version": "0.1.0",
    "identifier": "nz.warmot.app",
    "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
    },
    "app": {
    "windows": [
        {
        "title": "warmot – sensor viewer",
        "width": 1400,
        "height": 900,
        "resizable": true
        }
    ],
    "withGlobalTauri": true,
    "security": {
        "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
    }
}